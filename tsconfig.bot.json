{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "outDir": "./dist",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["telegram-bot.ts", "src/lib/agent/**/*.ts"],
  "exclude": [
    "node_modules",
    ".git",
    ".next",
    ".workspaces",
    ".vscode",
    "dist",
    "build",
    "logs",
    "workspace",
    "temp",
    "**/large_data",
    
  ]
}
